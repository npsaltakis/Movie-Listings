<?xml version="1.0" encoding="utf-8"?>
<metadata>
    <layout title="COM_MOVIELIST_MENU_CATEGORIES_TITLE">
        <message><![CDATA[COM_MOVIELIST_MENU_CATEGORIES_DESC]]></message>
    </layout>

    <!-- Request parameters shown when creating the menu item -->
    <fields name="request">
        <fieldset name="request">
            <field name="directory_id" type="sql"
                   label="COM_MOVIELIST_MENU_FIELD_DIRECTORY"
                   query="SELECT id AS value, title AS text FROM #__movielist_directories WHERE state = 1 ORDER BY title ASC"
                   key_field="value" value_field="text">
                <option value="0">COM_MOVIELIST_MENU_FIELD_ALL_DIRECTORIES</option>
            </field>
        </fieldset>
    </fields>
</metadata>
