<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset name="permissions" label="JCONFIG_PERMISSIONS_LABEL"
              description="JCONFIG_PERMISSIONS_DESC">
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               validate="rules" filter="rules" component="com_movielist" section="component" />
    </fieldset>

    <fieldset name="general" label="COM_MOVIELIST_CONFIG_GENERAL">
        <field name="movies_per_page" type="number" label="COM_MOVIELIST_CONFIG_MOVIES_PER_PAGE" default="20" />
        <field name="show_poster" type="radio" label="COM_MOVIELIST_CONFIG_SHOW_POSTER"
               layout="joomla.form.field.radio.switcher" default="1">
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
    </fieldset>
</config>
