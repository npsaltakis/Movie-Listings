<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Nickpsal\Component\Movielist\Administrator\Field">
    <fieldset name="details">
        <field name="id" type="number" label="JGLOBAL_FIELD_ID_LABEL" default="0" readonly="true" class="readonly" />

        <field name="title" type="text" label="COM_MOVIELIST_MOVIE_TITLE" required="true" size="50" />
        <field name="alias" type="text" label="JFIELD_ALIAS_LABEL" hint="JFIELD_ALIAS_PLACEHOLDER" size="50" />

        <field name="directory_id" type="directory" label="COM_MOVIELIST_FIELD_DIRECTORY" required="true">
            <option value="">COM_MOVIELIST_SELECT_DIRECTORY</option>
        </field>

        <field name="catid" type="movielistcategory" label="COM_MOVIELIST_FIELD_CATEGORY" required="true">
            <option value="">COM_MOVIELIST_SELECT_CATEGORY</option>
        </field>
    </fieldset>

    <fieldset name="media" label="COM_MOVIELIST_TAB_MEDIA">
        <field name="poster" type="media" label="COM_MOVIELIST_MOVIE_POSTER" />
    </fieldset>

    <fieldset name="gallery" label="COM_MOVIELIST_TAB_GALLERY">
        <field name="gallery" type="subform"
               label="COM_MOVIELIST_GALLERY_IMAGES"
               description="COM_MOVIELIST_GALLERY_DESC"
               multiple="true"
               layout="joomla.form.field.subform.repeatable-table">
            <form>
                <field name="image" type="media" label="COM_MOVIELIST_GALLERY_IMAGE" />
                <field name="caption" type="text" label="COM_MOVIELIST_GALLERY_CAPTION" />
                <field name="type" type="list" label="COM_MOVIELIST_GALLERY_TYPE" default="still">
                    <option value="still">COM_MOVIELIST_GALLERY_TYPE_STILL</option>
                    <option value="behind">COM_MOVIELIST_GALLERY_TYPE_BEHIND</option>
                    <option value="poster">COM_MOVIELIST_GALLERY_TYPE_POSTER</option>
                </field>
            </form>
        </field>
    </fieldset>

    <fieldset name="publishing" label="JGLOBAL_FIELDSET_PUBLISHING">
        <field name="state" type="list" label="JSTATUS" default="1">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field name="featured" type="radio" label="JFEATURED" layout="joomla.form.field.radio.switcher" default="0">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="access" type="accesslevel" label="JFIELD_ACCESS_LABEL" />
        <field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL">
            <option value="*">JALL</option>
        </field>
        <field name="ordering" type="number" label="JFIELD_ORDERING_LABEL" default="0" class="readonly" readonly="true" />
        <field name="metakey" type="textarea" label="JFIELD_META_KEYWORDS_LABEL" rows="3" cols="30" />
        <field name="metadesc" type="textarea" label="JFIELD_META_DESCRIPTION_LABEL" rows="3" cols="30" />
    </fieldset>
</form>
